{
  "name": "llm-wiki",
  "version": "0.0.0",
  "description": "A local-first CLI for maintaining an LLM-assisted Markdown wiki.",
  "type": "module",
  "bin": {
    "llm-wiki": "./dist/src/cli.js"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "lint": "tsc -p tsconfig.json --noEmit",
    "prepare": "npm run build",
    "prepack": "npm run build",
    "test": "npm run build && vitest run"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "typescript": "^5.8.3",
    "vitest": "^4.1.9",
    "yaml": "^2.9.0"
  },
  "dependencies": {
    "commander": "^14.0.3"
  }
}
